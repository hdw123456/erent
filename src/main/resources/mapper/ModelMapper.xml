<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.aigateway.mapper.ModelMapper">

    <select id="getAvailableModelsAndPricingByProviderCode" resultMap="ProviderModelPricingResultMap">
        SELECT p.id AS provider_id,
               p.code AS provider_code,
               p.name AS provider_name,
               m.id AS model_id,
               m.code AS model_code,
               m.display_name AS model_display_name,
               pr.input_token_price,
               pr.output_token_price,
               pr.currency
        FROM model m
        INNER JOIN provider p ON p.id = m.provider_id
        INNER JOIN pricing_rule pr ON pr.model_id = m.id
        WHERE p.code = #{providerCode}
          AND p.enabled = TRUE
          AND m.enabled = TRUE
          AND pr.enabled = TRUE
        ORDER BY m.code ASC, pr.created_at DESC
    </select>

    <resultMap id="ProviderModelPricingResultMap" type="com.example.aigateway.dto.ProviderModelPricing">
        <id property="modelId" column="model_id"/>
        <result property="providerId" column="provider_id"/>
        <result property="providerCode" column="provider_code"/>
        <result property="providerName" column="provider_name"/>
        <result property="modelCode" column="model_code"/>
        <result property="modelDisplayName" column="model_display_name"/>
        <result property="inputTokenPrice" column="input_token_price"/>
        <result property="outputTokenPrice" column="output_token_price"/>
        <result property="currency" column="currency"/>
    </resultMap>
</mapper>
