<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper  namespace="com.example.aigateway.mapper.ApiKeyMapper" >

    <insert id="insertApiKey" useGeneratedKeys="true" keyProperty="apiKey.id">
        INSERT INTO api_key (user_id, key_hash, name, prefix, created_at, updated_at)
        VALUES (#{userId}, #{apiKey.keyHash}, #{apiKey.name}, #{apiKey.prefix}, #{apiKey.createdAt}, #{apiKey.updatedAt})
    </insert>

    <select id="getUserApi" resultMap="apiKeyResultMap">
        SELECT * FROM api_key WHERE user_id = #{userId}
    </select>

    <select id="getApiKeyByName" resultMap="apiKeyResultMap">
        SELECT * FROM api_key WHERE name = #{apiName}
    </select>

    <select id="getApiKeyById" resultMap="apiKeyResultMap">
        SELECT * FROM api_key WHERE id = #{apiKeyId}
    </select>

    <select id="getApiKeyByKeyHash" resultMap="apiKeyResultMap">
        SELECT * FROM api_key WHERE key_hash = #{keyHash}
    </select>

    <update id="updateApiKey" parameterType="com.example.aigateway.entity.ApiKey">
        UPDATE api_key
        SET name = #{name}, prefix = #{prefix}, updated_at = CURRENT_TIMESTAMP, enabled = #{enabled}
        WHERE id = #{id}
    </update>

    <update id="updateLastUsedAt">
        UPDATE api_key
        SET last_used_at = CURRENT_TIMESTAMP, updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <delete id="deleteApiKey" parameterType="com.example.aigateway.entity.ApiKey">
        DELETE FROM api_key WHERE id = #{id}
    </delete>

    <resultMap id="apiKeyResultMap" type="com.example.aigateway.entity.ApiKey">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="keyHash" column="key_hash"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="lastUsedAt" column="last_used_at"/>
        <result property="prefix" column="prefix"/>
        <result property="name" column="name"/>
        <result property="enabled" column="enabled"/>
    </resultMap>
</mapper>
