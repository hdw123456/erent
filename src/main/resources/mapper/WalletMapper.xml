<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.aigateway.mapper.WalletMapper">

    <insert id="insertWallet" parameterType="com.example.aigateway.entity.Wallet" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wallet (user_id, balance)
        VALUES (#{userId}, #{balance})
    </insert>

    <select id="getWalletByUserId" resultMap="WalletResultMap">
        SELECT id, user_id, balance, created_at, updated_at
        FROM wallet
        WHERE user_id = #{userId}
    </select>

    <select id="getWalletByUserIdForUpdate" resultMap="WalletResultMap">
        SELECT id, user_id, balance, created_at, updated_at
        FROM wallet
        WHERE user_id = #{userId}
        FOR UPDATE
    </select>

    <select id="getBalanceByUserId" resultType="java.math.BigDecimal">
        SELECT balance
        FROM wallet
        WHERE user_id = #{userId}
    </select>

    <select id="getLowBalanceUsersWithEnabledApiKeys" resultMap="LowBalanceUserResultMap">
        SELECT u.id AS user_id,
               u.username,
               w.balance,
               COUNT(k.id) AS enabled_api_key_count
        FROM wallet w
        INNER JOIN user_account u ON u.id = w.user_id
        INNER JOIN api_key k ON k.user_id = u.id AND k.enabled = TRUE
        WHERE w.balance &lt; #{minBalance}
        GROUP BY u.id, u.username, w.balance
        ORDER BY w.balance ASC, u.id ASC
    </select>

    <update id="updateBalance">
        UPDATE wallet
        SET balance = #{balance}
        WHERE user_id = #{userId}
    </update>

    <resultMap id="WalletResultMap" type="com.example.aigateway.entity.Wallet">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="balance" column="balance"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="LowBalanceUserResultMap" type="com.example.aigateway.dto.LowBalanceUser">
        <id property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="balance" column="balance"/>
        <result property="enabledApiKeyCount" column="enabled_api_key_count"/>
    </resultMap>
</mapper>
