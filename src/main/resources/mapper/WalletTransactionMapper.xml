<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.aigateway.mapper.WalletTransactionMapper">

    <insert id="insertWalletTransaction" parameterType="com.example.aigateway.entity.WalletTransaction"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wallet_transaction (
            wallet_id, type, amount, balance_after, request_id
        )
        VALUES (
            #{walletId}, #{type}, #{amount}, #{balanceAfter}, #{requestId}
        )
    </insert>
</mapper>
