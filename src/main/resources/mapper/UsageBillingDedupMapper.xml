<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.aigateway.mapper.UsageBillingDedupMapper">

    <sql id="BaseColumns">
        id, request_id, api_key_id, request_fingerprint, created_at
    </sql>

    <insert id="insertUsageBillingDedup" parameterType="com.example.aigateway.entity.UsageBillingDedup"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO usage_billing_dedup (
            request_id, api_key_id, request_fingerprint
        )
        VALUES (
            #{requestId}, #{apiKeyId}, #{requestFingerprint}
        )
    </insert>

    <insert id="insertUsageBillingDedupIgnore" parameterType="com.example.aigateway.entity.UsageBillingDedup"
            useGeneratedKeys="true" keyProperty="id">
        INSERT IGNORE INTO usage_billing_dedup (
            request_id, api_key_id, request_fingerprint
        )
        VALUES (
            #{requestId}, #{apiKeyId}, #{requestFingerprint}
        )
    </insert>

    <select id="getByRequestIdAndApiKeyId" resultMap="UsageBillingDedupResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM usage_billing_dedup
        WHERE request_id = #{requestId}
          AND api_key_id = #{apiKeyId}
    </select>

    <select id="getByRequestIdAndApiKeyIdForUpdate" resultMap="UsageBillingDedupResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM usage_billing_dedup
        WHERE request_id = #{requestId}
          AND api_key_id = #{apiKeyId}
        FOR UPDATE
    </select>

    <resultMap id="UsageBillingDedupResultMap" type="com.example.aigateway.entity.UsageBillingDedup">
        <id property="id" column="id"/>
        <result property="requestId" column="request_id"/>
        <result property="apiKeyId" column="api_key_id"/>
        <result property="requestFingerprint" column="request_fingerprint"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
</mapper>
