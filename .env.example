# Local defaults are suitable only for a developer workstation.
# Production must replace every credential and keep the real .env off Git.
DB_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
RABBITMQ_PASSWORD=replace-with-a-strong-rabbitmq-password
JASYPT_PASSWORD=replace-with-the-stable-provider-key-encryption-password
JWT_SECRET=replace-with-a-base64-encoded-jwt-secret

NACOS_USERNAME=nacos
NACOS_ADMIN_PASSWORD=replace-with-a-strong-nacos-admin-password
NACOS_AUTH_TOKEN=replace-with-base64-of-at-least-32-random-bytes
NACOS_AUTH_IDENTITY_KEY=replace-with-a-random-server-identity-key
NACOS_AUTH_IDENTITY_VALUE=replace-with-a-random-server-identity-value

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password

OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=AI Gateway Learning
